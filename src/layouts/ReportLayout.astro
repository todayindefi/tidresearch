---
import BaseLayout from "./BaseLayout.astro";
import RiskSidebar from "@/components/report/RiskSidebar.astro";
import DashboardEmbed from "@/components/report/DashboardEmbed.astro";
import ScoreHero from "@/components/report/ScoreHero.astro";
import StickyToc from "@/components/report/StickyToc.astro";
import CollapsibleSections from "@/components/report/CollapsibleSections.astro";
import EmailWatermark from "@/components/report/EmailWatermark.astro";
import TrustDisclaimer from "@/components/report/TrustDisclaimer.astro";
import { ArrowRight, Download, Printer } from "lucide-react";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  data: any;
  hasDashboard?: boolean;
  headings?: Heading[];
}

const { data, hasDashboard = false, headings = [] } = Astro.props;
const description = `${data.asset} risk assessment — ${data.category.replace("-", " ")} | TID Research`;

const liveDashboardUrl: string | undefined = data.live_dashboard_url;
const pdfComingSoon: boolean = Boolean(data.pdf_coming_soon);
const hasCta = Boolean(liveDashboardUrl) || pdfComingSoon;
const isInstitutional = data.audience === "institutional";
const showTrustDisclaimer: boolean = Boolean(data.trust_disclaimer);
---

<BaseLayout title={`${data.asset} — Risk Assessment | TID Research`} description={description}>
  <article class={`container-page py-12 ${isInstitutional ? "institutional-report" : ""}`}>
    <div class="mb-8 print-hide flex items-center justify-between gap-4">
      <a
        href="/reports"
        class="text-xs uppercase tracking-wider text-muted-foreground hover:text-primary font-mono"
      >
        ← All Reports
      </a>
      <div class="flex items-center gap-2">
        {liveDashboardUrl && (
          <a
            href={liveDashboardUrl}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-4 py-2 text-xs font-mono uppercase tracking-wider hover:bg-primary/90 transition-colors no-underline"
          >
            Open Live Dashboard
            <ArrowRight className="h-3.5 w-3.5" />
          </a>
        )}
        {isInstitutional && (
          <button
            type="button"
            data-print-button
            class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-4 py-2 text-xs font-mono uppercase tracking-wider hover:bg-primary/90 transition-colors"
          >
            <Printer className="h-3.5 w-3.5" />
            Save as PDF
          </button>
        )}
      </div>
    </div>

    {isInstitutional && <EmailWatermark />}
    {isInstitutional ? (
      <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr] gap-12 institutional-grid">
        <StickyToc headings={headings} />
        <div class="min-w-0">
          {showTrustDisclaimer && (
            <TrustDisclaimer dashboardUrl={liveDashboardUrl} />
          )}
          <ScoreHero data={data} />
          <div class="prose-report prose-institutional" data-collapsible-root>
            <slot />
          </div>
          <CollapsibleSections />
          {hasDashboard && (
            <section class="mt-12">
              <h2 class="text-2xl font-bold mb-4">Live Backing Dashboard</h2>
              <DashboardEmbed
                slug={data.slug}
                url={liveDashboardUrl}
                height={liveDashboardUrl ? "900px" : "700px"}
              />
            </section>
          )}
          {liveDashboardUrl && (
            <section class="mt-12 border-t border-border pt-8 flex flex-wrap gap-3 print-hide">
              <a
                href={liveDashboardUrl}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-5 py-3 text-sm font-mono uppercase tracking-wider hover:bg-primary/90 transition-colors no-underline"
              >
                Open live dashboard
                <ArrowRight className="h-4 w-4" />
              </a>
            </section>
          )}
        </div>
      </div>
    ) : (
      <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-12">
        <div class="min-w-0">
          {showTrustDisclaimer && (
            <TrustDisclaimer dashboardUrl={liveDashboardUrl} />
          )}
          <div class="prose-report">
            <slot />
            {hasDashboard && (
              <section class="mt-12">
                <h2 class="text-2xl font-bold mb-4">Live Backing Dashboard</h2>
                <DashboardEmbed
                  slug={data.slug}
                  url={liveDashboardUrl}
                  height={liveDashboardUrl ? "900px" : "700px"}
                />
              </section>
            )}
          </div>
          {hasCta && (
            <section class="mt-12 border-t border-border pt-8 flex flex-wrap gap-3">
              {liveDashboardUrl && (
                <a
                  href={liveDashboardUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-5 py-3 text-sm font-mono uppercase tracking-wider hover:bg-primary/90 transition-colors no-underline"
                >
                  Open live dashboard
                  <ArrowRight className="h-4 w-4" />
                </a>
              )}
              {pdfComingSoon && (
                <button
                  type="button"
                  disabled
                  class="inline-flex items-center gap-2 border border-border bg-card text-muted-foreground px-5 py-3 text-sm font-mono uppercase tracking-wider cursor-not-allowed"
                >
                  <Download className="h-4 w-4" />
                  Download full PDF (coming soon)
                </button>
              )}
            </section>
          )}
        </div>
        <div class="lg:sticky lg:top-28 lg:self-start">
          <RiskSidebar data={data} />
        </div>
      </div>
    )}
  </article>
</BaseLayout>

<script>
  // Wire "Save as PDF" buttons to window.print(), and ensure all collapsible
  // sections are open before printing so nothing is hidden in the saved PDF.
  document.querySelectorAll<HTMLButtonElement>("[data-print-button]").forEach((btn) => {
    btn.addEventListener("click", () => window.print());
  });
  window.addEventListener("beforeprint", () => {
    document
      .querySelectorAll<HTMLDetailsElement>("details.report-section")
      .forEach((d) => {
        d.dataset.prevOpen = d.open ? "1" : "0";
        d.open = true;
      });
  });
  window.addEventListener("afterprint", () => {
    document
      .querySelectorAll<HTMLDetailsElement>("details.report-section")
      .forEach((d) => {
        if (d.dataset.prevOpen === "0") d.open = false;
        delete d.dataset.prevOpen;
      });
  });
</script>
