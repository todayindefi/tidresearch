---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/ui/Button.astro";
---

<BaseLayout title="Not Found | TID Research" description="Page not found.">
  <section class="container-page py-32 text-center">
    <p class="eyebrow mb-4">404</p>
    <h1 class="text-5xl md:text-7xl font-bold mb-6">Page not found</h1>
    <p class="text-muted-foreground mb-10 max-w-md mx-auto">
      The page you're looking for doesn't exist or has moved.
    </p>
    <div class="flex justify-center gap-4 flex-wrap">
      <Button href="/" size="lg">Back to home</Button>
      <Button href="/reports" variant="outline" size="lg">View reports</Button>
    </div>
  </section>
</BaseLayout>
