---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ReportsFilter from "@/components/islands/ReportsFilter.tsx";
import { getCollection } from "astro:content";
import { chainLabel } from "@/lib/chains";
import { visibleAtCurrentStage } from "@/lib/stage";

const all = await getCollection("reports");

// Slugs whose institutional companion should also appear in the listing
// (rendered as a "Request access" card by ReportsFilter). Other institutional
// reports stay hidden behind their retail summary's sidebar CTA.
const PROMOTE_INSTITUTIONAL = new Set(["syrupusdc-full", "syrupusdt-full"]);

const visible = all
  .filter((r) => visibleAtCurrentStage(r.data))
  .filter(
    (r) => r.data.audience !== "institutional" || PROMOTE_INSTITUTIONAL.has(r.data.slug),
  );

const toRow = (r: (typeof visible)[number]) => ({
  slug: r.data.slug,
  asset: r.data.asset,
  category: r.data.category,
  assessment_type: r.data.assessment_type,
  audience: r.data.audience,
  chains: r.data.chains,
  chain_labels: Array.from(new Set(r.data.chains.map(chainLabel))),
  overall_score: r.data.overall_score,
  last_verified: new Date(r.data.last_verified).toISOString().slice(0, 10),
  featured: Boolean(r.data.featured),
  companion_report: r.data.companion_report,
});

// Featured first, then most-recently verified.
const baseSorted = visible.map(toRow).sort((a, b) => {
  if (a.featured !== b.featured) return a.featured ? -1 : 1;
  return b.last_verified.localeCompare(a.last_verified);
});

// Insert each promoted institutional card immediately after its retail
// companion so the retail → "request institutional" path reads as one unit.
// companion_report is set on the institutional side and points back to the
// retail slug, so we invert it here (retailSlug → institutional row).
const institutionalForRetail = new Map<string, (typeof baseSorted)[number]>();
for (const row of baseSorted) {
  if (row.audience === "institutional" && row.companion_report) {
    institutionalForRetail.set(row.companion_report, row);
  }
}
const consumed = new Set<string>();
const rows: typeof baseSorted = [];
for (const row of baseSorted) {
  if (row.audience === "institutional" && consumed.has(row.slug)) continue;
  rows.push(row);
  if (row.audience !== "institutional") {
    const companion = institutionalForRetail.get(row.slug);
    if (companion && !consumed.has(companion.slug)) {
      rows.push(companion);
      consumed.add(companion.slug);
    }
  }
}
---

<BaseLayout
  title="Risk Reports | TID Research"
  description="Asset risk reports — tokenized treasuries (RWA), lending vaults, stablecoins, wrapped tokens, vault shares. Filter by chain, category, and risk score."
>
  <section class="container-page py-16">
    <div class="mb-10">
      <p class="eyebrow mb-3">Research</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Risk Reports</h1>
      <p class="text-muted-foreground max-w-2xl">
        Independent risk assessments paired with live on-chain dashboards. Filter by
        chain, category, or risk score.
      </p>
    </div>

    {
      rows.length > 0 ? (
        <ReportsFilter client:load reports={rows} />
      ) : (
        <div class="border border-border bg-card p-12 text-center text-muted-foreground">
          New reports coming soon.
        </div>
      )
    }
  </section>
</BaseLayout>
