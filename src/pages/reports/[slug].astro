---
import { getCollection, render } from "astro:content";
import ReportLayout from "@/layouts/ReportLayout.astro";
import { visibleAtCurrentStage } from "@/lib/stage";

export async function getStaticPaths() {
  const reports = await getCollection("reports");
  return reports
    .filter((r) => visibleAtCurrentStage(r.data))
    .map((r) => ({
      params: { slug: r.data.slug },
      props: { entry: r },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Slugs with a live dashboard. Most iframe backing-monitor by slug;
// thBILL has its own standalone dashboard repo referenced via the
// report's live_dashboard_url frontmatter field. Only the institutional
// thBILL page shows the dashboard; the retail summary stays clean.
const DASHBOARD_SLUGS = new Set([
  "crvusd",
  "usdd",
  "ousd",
  "thbill-full",
  "syrupusdc",
  "syrupusdt",
  "apxusd",
  "apyusd",
  "usdat",
  "susdat",
  "strcx",
  "mstr",
  "bmnr",
  "usde",
  "susde",
  "usdai",
  "susdai",
]);
const hasDashboard = DASHBOARD_SLUGS.has(entry.data.slug);

// Single source of truth for the dashboard *link* surfaces (sidebar button, bottom CTA,
// trust disclaimer): an explicit live_dashboard_url wins (e.g. thBILL's standalone
// dashboard); otherwise any slug in DASHBOARD_SLUGS falls back to its internal
// backing-monitor view. This keeps the link present on every dashboard-enabled report —
// including syrup, which is in DASHBOARD_SLUGS but has no live_dashboard_url frontmatter.
const dashboardUrl =
  entry.data.live_dashboard_url ??
  (hasDashboard ? `/dashboards/?asset=${entry.data.slug}` : undefined);
---

<ReportLayout data={entry.data} hasDashboard={hasDashboard} headings={headings} dashboardUrl={dashboardUrl}>
  <Content />
</ReportLayout>
