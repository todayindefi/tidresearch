---
import { getCollection, render } from "astro:content";
import ReportLayout from "@/layouts/ReportLayout.astro";
import { visibleAtCurrentStage } from "@/lib/stage";

export async function getStaticPaths() {
  const reports = await getCollection("reports");
  return reports
    .filter((r) => visibleAtCurrentStage(r.data))
    .map((r) => ({
      params: { slug: r.data.slug },
      props: { entry: r },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Slugs with a live dashboard. Most iframe backing-monitor by slug;
// thBILL has its own standalone dashboard repo referenced via the
// report's live_dashboard_url frontmatter field. Only the institutional
// thBILL page shows the dashboard; the retail summary stays clean.
const DASHBOARD_SLUGS = new Set([
  "crvusd",
  "usdd",
  "ousd",
  "thbill-full",
  "syrupusdc",
  "syrupusdt",
]);
const hasDashboard = DASHBOARD_SLUGS.has(entry.data.slug);
---

<ReportLayout data={entry.data} hasDashboard={hasDashboard} headings={headings}>
  <Content />
</ReportLayout>
