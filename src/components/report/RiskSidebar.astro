---
import { getEntry } from "astro:content";
import RiskBadge from "./RiskBadge.astro";
import Badge from "../ui/Badge.astro";
import { chainLabel } from "@/lib/chains";
import { ArrowRight } from "lucide-react";

interface Props {
  data: any;
}

const { data } = Astro.props;
const liveDashboardUrl: string | undefined = data.live_dashboard_url;

// Companion report cross-link. The historical pattern (syrupUSDC, thBILL, etc.)
// is retail → institutional, where the CTA routes to /<companion>/request for
// gated access. Saturn (USDat/sUSDat) introduces a retail-retail sibling pattern
// where the companion is also a public report and the CTA should link directly.
const companionEntry =
  data.audience === "retail" && data.companion_report
    ? await getEntry("reports", data.companion_report)
    : null;
const companionIsRetailSibling = companionEntry?.data?.audience === "retail";

type Axis = { key: string; label: string };

const AXES_BY_CATEGORY: Record<string, Axis[]> = {
  stablecoin: [
    { key: "peg_mechanism_score", label: "Peg Mechanism" },
    { key: "backing_score", label: "Backing" },
    { key: "underlying_score", label: "Underlying" },
    { key: "liquidity_score", label: "Liquidity" },
    { key: "issuer_score", label: "Issuer" },
  ],
  "wrapped-token": [
    { key: "volatility_score", label: "Stability" },
    { key: "structural_score", label: "Contract & Admin" },
    { key: "redemption_score", label: "Redemption" },
    { key: "underlying_score", label: "Underlying" },
    { key: "liquidity_score", label: "Liquidity" },
    { key: "issuer_score", label: "Issuer" },
  ],
  "vault-share": [
    { key: "volatility_score", label: "Stability" },
    { key: "structural_score", label: "Contract & Admin" },
    { key: "redemption_score", label: "Redemption" },
    { key: "underlying_score", label: "Underlying" },
    { key: "liquidity_score", label: "Liquidity" },
    { key: "issuer_score", label: "Issuer" },
  ],
  "tokenized-treasury": [
    { key: "contract_score", label: "Smart Contract" },
    { key: "economic_score", label: "Economic" },
    { key: "project_score", label: "Project" },
    { key: "supply_integrity_score", label: "Supply Integrity" },
  ],
  "lending-vault": [
    { key: "contract_score", label: "Smart Contract" },
    { key: "credit_score", label: "Credit" },
    { key: "liquidity_score", label: "Liquidity" },
    { key: "operational_score", label: "Operational" },
    { key: "supply_integrity_score", label: "Supply Integrity" },
  ],
};

const isStable = data.category === "stablecoin";
const isRwa = data.category === "tokenized-treasury";
const isLendingVault = data.category === "lending-vault";

// Retail RWA reports score on peg/backing/liquidity/issuer (the stablecoin rubric)
// rather than the institutional contract/economic/project rubric, because retail users
// without primary-redemption access need peg and liquidity surfaced as their own dials.
const useStablecoinAxes =
  isRwa && typeof data.peg_mechanism_score === "number";

const axes = useStablecoinAxes
  ? AXES_BY_CATEGORY.stablecoin
  : (AXES_BY_CATEGORY[data.category as string] ?? []);

const weights: Record<string, number> | null =
  isRwa && !useStablecoinAxes && data.score_weights
    ? {
        contract_score: data.score_weights.contract,
        economic_score: data.score_weights.economic,
        project_score: data.score_weights.project,
      }
    : isLendingVault && data.score_weights
    ? {
        contract_score: data.score_weights.contract,
        credit_score: data.score_weights.credit,
        liquidity_score: data.score_weights.liquidity,
        operational_score: data.score_weights.operational,
      }
    : null;

const fmtUSD = (n?: number) =>
  typeof n === "number"
    ? n >= 1e9
      ? `$${(n / 1e9).toFixed(2)}B`
      : n >= 1e6
        ? `$${(n / 1e6).toFixed(0)}M`
        : `$${n.toLocaleString()}`
    : null;

const fmtDate = (d: Date) => new Date(d).toISOString().slice(0, 10);

const categoryLabel = (c: string) =>
  c === "tokenized-treasury"
    ? "Tokenized Treasury (RWA)"
    : c === "lending-vault"
    ? "Lending Vault"
    : c.replace("-", " ");
---

<aside class="bg-card border border-border p-6 space-y-6 text-sm">
  <div>
    <div class="eyebrow mb-2">Overall Score</div>
    <RiskBadge score={data.overall_score} size="lg" />
    <p class="text-xs text-muted-foreground mt-2">
      Scale 1–10. Higher is safer.
      {(isRwa || isLendingVault) && weights && (
        <span class="block mt-1">Weighted composite — see report §IV/§V.</span>
      )}
    </p>
  </div>

  {liveDashboardUrl && (
    <div>
      <div class="eyebrow mb-2">Live Data</div>
      <a
        href={liveDashboardUrl}
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-4 py-2 text-xs font-mono uppercase tracking-wider hover:bg-primary/90 transition-colors no-underline w-full justify-center"
      >
        Open dashboard
        <ArrowRight className="h-3.5 w-3.5" />
      </a>
      <p class="text-xs text-muted-foreground mt-2">
        Live reserves, collateralization, peg, and bridge state — updated hourly.
      </p>
    </div>
  )}

  <div>
    <div class="eyebrow mb-3">Score Breakdown</div>
    <div class="space-y-2">
      {
        axes.map((a) => {
          const v = data[a.key];
          if (typeof v !== "number") return null;
          const w = weights?.[a.key];
          return (
            <div class="flex items-center justify-between">
              <span class="text-muted-foreground">
                {a.label}
                {w && (
                  <span class="text-muted-foreground/60 font-mono text-xs ml-1">
                    {Math.round(w * 100)}%
                  </span>
                )}
              </span>
              <RiskBadge score={v} size="sm" />
            </div>
          );
        })
      }
    </div>
  </div>

  <div class="border-t border-border pt-4 space-y-3">
    <div>
      <div class="eyebrow mb-1">Category</div>
      <div class="capitalize">{categoryLabel(data.category)}</div>
    </div>

    {
      (isStable || isRwa) && data.peg_mechanism && (
        <div>
          <div class="eyebrow mb-1">Peg Mechanism</div>
          <div class="capitalize">{data.peg_mechanism}</div>
        </div>
      )
    }

    {
      (isStable || isRwa || isLendingVault) && data.issuer && (
        <div>
          <div class="eyebrow mb-1">Issuer</div>
          <div>{data.issuer}</div>
        </div>
      )
    }

    {
      isRwa && data.credit_rating_equiv && (
        <div>
          <div class="eyebrow mb-1">Credit Equivalent</div>
          <div class="font-mono">{data.credit_rating_equiv}</div>
        </div>
      )
    }

    {
      (isRwa || isLendingVault) && data.legal_jurisdiction && (
        <div>
          <div class="eyebrow mb-1">Jurisdiction</div>
          <div>{data.legal_jurisdiction}</div>
        </div>
      )
    }

    {
      isRwa && typeof data.settlement_lag_days === "number" && (
        <div>
          <div class="eyebrow mb-1">Redemption</div>
          <div class="font-mono">USDC · T+{data.settlement_lag_days}</div>
        </div>
      )
    }

    {
      (isRwa || isLendingVault) && data.underlying_managers?.length > 0 && (
        <div>
          <div class="eyebrow mb-1">{isLendingVault ? "Operators / Delegates" : "Underlying Managers"}</div>
          <ul class="space-y-1">
            {data.underlying_managers.map((m: string) => (
              <li class="text-xs">{m}</li>
            ))}
          </ul>
        </div>
      )
    }

    {
      (isStable || isRwa || isLendingVault) && fmtUSD(data.market_cap_approx ?? data.tvl_gross) && (
        <div>
          <div class="eyebrow mb-1">{isLendingVault ? "Pool TVL" : "Market Cap"}</div>
          <div class="font-mono">{fmtUSD(data.market_cap_approx ?? data.tvl_gross)}</div>
        </div>
      )
    }

    {
      !isStable && !isRwa && data.underlying_assets?.length > 0 && (
        <div>
          <div class="eyebrow mb-1">Underlying</div>
          <div class="flex flex-wrap gap-1">
            {data.underlying_assets.map((u: string) => (
              <Badge variant="muted">{u}</Badge>
            ))}
          </div>
        </div>
      )
    }

    <div>
      <div class="eyebrow mb-1">Chains</div>
      <div class="flex flex-wrap gap-1">
        {data.chains.map((c: string) => <Badge variant="outline">{chainLabel(c)}</Badge>)}
      </div>
    </div>

    <div>
      <div class="eyebrow mb-1">Last Verified</div>
      <div class="font-mono">{fmtDate(data.last_verified)}</div>
    </div>
  </div>

  {
    data.audience === "retail" && data.companion_report && !companionIsRetailSibling && (
      <a
        href={`/reports/${data.companion_report}/request`}
        class="block border-t border-border pt-4 -mx-6 -mb-6 px-6 pb-6 hover:bg-primary/5 transition-colors group"
      >
        <div class="eyebrow mb-2 text-primary/80">Institutional Report</div>
        <p class="text-sm text-foreground mb-2">
          Full audit findings, bridge architecture, DVN configuration, governance,
          and peer comparison.
        </p>
        <span class="text-xs font-mono uppercase tracking-wider text-primary group-hover:underline">
          Request access →
        </span>
      </a>
    )
  }
  {
    companionIsRetailSibling && companionEntry && (
      <a
        href={`/reports/${companionEntry.data.slug}/`}
        class="block border-t border-border pt-4 -mx-6 -mb-6 px-6 pb-6 hover:bg-primary/5 transition-colors group"
      >
        <div class="eyebrow mb-2 text-primary/80">Paired Report</div>
        <p class="text-sm text-foreground mb-2">
          {companionEntry.data.asset} — paired sibling on the same issuer
          infrastructure. Different risk profile, complementary read.
        </p>
        <span class="text-xs font-mono uppercase tracking-wider text-primary group-hover:underline">
          Read {companionEntry.data.asset} →
        </span>
      </a>
    )
  }
</aside>
