---
import RiskBadge from "./RiskBadge.astro";
import Badge from "../ui/Badge.astro";
import { chainLabel } from "@/lib/chains";

interface Props {
  data: any;
}

const { data } = Astro.props;

type Axis = { key: string; label: string };

const AXES_BY_CATEGORY: Record<string, Axis[]> = {
  stablecoin: [
    { key: "peg_mechanism_score", label: "Peg Mechanism" },
    { key: "backing_score", label: "Backing" },
    { key: "liquidity_score", label: "Liquidity" },
    { key: "issuer_score", label: "Issuer" },
  ],
  "wrapped-token": [
    { key: "volatility_score", label: "Volatility" },
    { key: "liquidity_score", label: "Liquidity" },
    { key: "structural_score", label: "Structural" },
    { key: "redemption_score", label: "Redemption" },
  ],
  "vault-share": [
    { key: "volatility_score", label: "Volatility" },
    { key: "liquidity_score", label: "Liquidity" },
    { key: "structural_score", label: "Structural" },
    { key: "redemption_score", label: "Redemption" },
  ],
  "tokenized-treasury": [
    { key: "contract_score", label: "Smart Contract" },
    { key: "economic_score", label: "Economic" },
    { key: "project_score", label: "Project" },
    { key: "supply_integrity_score", label: "Supply Integrity" },
  ],
};

const axes = AXES_BY_CATEGORY[data.category as string] ?? [];
const isStable = data.category === "stablecoin";
const isRwa = data.category === "tokenized-treasury";

const weights: Record<string, number> | null = isRwa && data.score_weights
  ? {
      contract_score: data.score_weights.contract,
      economic_score: data.score_weights.economic,
      project_score: data.score_weights.project,
    }
  : null;

const fmtUSD = (n?: number) =>
  typeof n === "number"
    ? n >= 1e9
      ? `$${(n / 1e9).toFixed(2)}B`
      : n >= 1e6
        ? `$${(n / 1e6).toFixed(0)}M`
        : `$${n.toLocaleString()}`
    : null;

const fmtDate = (d: Date) => new Date(d).toISOString().slice(0, 10);

const categoryLabel = (c: string) =>
  c === "tokenized-treasury" ? "Tokenized Treasury (RWA)" : c.replace("-", " ");
---

<aside class="bg-card border border-border p-6 space-y-6 text-sm">
  <div>
    <div class="eyebrow mb-2">Overall Score</div>
    <RiskBadge score={data.overall_score} size="lg" />
    <p class="text-xs text-muted-foreground mt-2">
      Scale 1–10. Higher is safer.
      {isRwa && weights && (
        <span class="block mt-1">Weighted composite — see §IV.</span>
      )}
    </p>
  </div>

  <div>
    <div class="eyebrow mb-3">Score Breakdown</div>
    <div class="space-y-2">
      {
        axes.map((a) => {
          const v = data[a.key];
          if (typeof v !== "number") return null;
          const w = weights?.[a.key];
          return (
            <div class="flex items-center justify-between">
              <span class="text-muted-foreground">
                {a.label}
                {w && (
                  <span class="text-muted-foreground/60 font-mono text-xs ml-1">
                    {Math.round(w * 100)}%
                  </span>
                )}
              </span>
              <RiskBadge score={v} size="sm" />
            </div>
          );
        })
      }
    </div>
  </div>

  <div class="border-t border-border pt-4 space-y-3">
    <div>
      <div class="eyebrow mb-1">Category</div>
      <div class="capitalize">{categoryLabel(data.category)}</div>
    </div>

    {
      isStable && data.peg_mechanism && (
        <div>
          <div class="eyebrow mb-1">Peg Mechanism</div>
          <div class="capitalize">{data.peg_mechanism}</div>
        </div>
      )
    }

    {
      (isStable || isRwa) && data.issuer && (
        <div>
          <div class="eyebrow mb-1">Issuer</div>
          <div>{data.issuer}</div>
        </div>
      )
    }

    {
      isRwa && data.credit_rating_equiv && (
        <div>
          <div class="eyebrow mb-1">Credit Equivalent</div>
          <div class="font-mono">{data.credit_rating_equiv}</div>
        </div>
      )
    }

    {
      isRwa && data.legal_jurisdiction && (
        <div>
          <div class="eyebrow mb-1">Jurisdiction</div>
          <div>{data.legal_jurisdiction}</div>
        </div>
      )
    }

    {
      isRwa && typeof data.settlement_lag_days === "number" && (
        <div>
          <div class="eyebrow mb-1">Redemption</div>
          <div class="font-mono">USDC · T+{data.settlement_lag_days}</div>
        </div>
      )
    }

    {
      isRwa && data.underlying_managers?.length > 0 && (
        <div>
          <div class="eyebrow mb-1">Underlying Managers</div>
          <ul class="space-y-1">
            {data.underlying_managers.map((m: string) => (
              <li class="text-xs">{m}</li>
            ))}
          </ul>
        </div>
      )
    }

    {
      (isStable || isRwa) && fmtUSD(data.market_cap_approx) && (
        <div>
          <div class="eyebrow mb-1">Market Cap</div>
          <div class="font-mono">{fmtUSD(data.market_cap_approx)}</div>
        </div>
      )
    }

    {
      !isStable && !isRwa && data.underlying_assets?.length > 0 && (
        <div>
          <div class="eyebrow mb-1">Underlying</div>
          <div class="flex flex-wrap gap-1">
            {data.underlying_assets.map((u: string) => (
              <Badge variant="muted">{u}</Badge>
            ))}
          </div>
        </div>
      )
    }

    <div>
      <div class="eyebrow mb-1">Chains</div>
      <div class="flex flex-wrap gap-1">
        {data.chains.map((c: string) => <Badge variant="outline">{chainLabel(c)}</Badge>)}
      </div>
    </div>

    <div>
      <div class="eyebrow mb-1">Last Verified</div>
      <div class="font-mono">{fmtDate(data.last_verified)}</div>
    </div>
  </div>
</aside>
