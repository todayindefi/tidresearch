---
interface Props {
  slug: string;
  title?: string;
  height?: string;
  url?: string;
  embed?: boolean;
}

const {
  slug,
  title = "Live backing dashboard",
  height = "600px",
  url,
  embed = true,
} = Astro.props;
const src = url ?? `/dashboards/?asset=${encodeURIComponent(slug)}`;
---

<div class="border border-border bg-card">
  <div class="flex items-center justify-between px-4 py-2 border-b border-border bg-background/50">
    <span class="eyebrow">Live data</span>
    <a
      href={src}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-primary hover:underline font-mono"
    >
      Open in new tab ↗
    </a>
  </div>
  {embed ? (
    <iframe
      src={src}
      title={title}
      loading="lazy"
      style={`width: 100%; height: ${height}; border: 0; display: block;`}
    ></iframe>
  ) : (
    <a
      href={src}
      target="_blank"
      rel="noopener noreferrer"
      class="block px-4 py-8 text-center hover:bg-background/50 transition-colors"
    >
      <div class="text-sm font-mono text-muted-foreground uppercase tracking-wider mb-1">
        External dashboard
      </div>
      <div class="text-primary hover:underline font-semibold">
        Open {title} ↗
      </div>
    </a>
  )}
</div>
