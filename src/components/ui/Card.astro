---
import { cn } from "@/lib/utils";

interface Props {
  href?: string;
  class?: string;
  hoverable?: boolean;
}

const { href, class: className, hoverable = false } = Astro.props;
const classes = cn(
  "block bg-card border border-border/60 rounded-none p-6",
  hoverable &&
    "transition-all duration-300 hover:border-primary/60 hover:shadow-[0_0_30px_-5px_hsl(var(--primary)/0.2)] group",
  className,
);
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <div class={classes}>
      <slot />
    </div>
  )
}
